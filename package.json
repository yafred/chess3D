{
  "name": "lichess-oauth-app-example",
  "private": true,
  "license": "MIT",
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint",
    "dev": "vite",
    "dev:full": "concurrently -k -n chessground,app \"pnpm --dir ../chessground exec tsc --sourceMap --declaration --watch\" \"vite\"",
    "build": "vite build",
    "serve": "vite preview",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@bity/oauth2-auth-code-pkce": "^2",
    "@lichess-org/chessground": "^10.1.1",
    "bootstrap": "^5",
    "chessops": "^0.10.5",
    "page": "^1",
    "snabbdom": "^3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/page": "^1",
    "@types/three": "^0.183.1",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "sass": "^1",
    "tslib": "^2",
    "typescript": "^5.6.3",
    "vite": "^5"
  },
  "packageManager": "pnpm@10.32.1"
}

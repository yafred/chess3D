{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "printWidth": 110,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "ignorePatterns": ["**/dist"],
  "sortPackageJson": false,
  "sortImports": {
    "groups": [
      ["builtin", "external"],
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ]
  }
}
